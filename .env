# Flask Settings
FLASK_APP=run.py
FLASK_RUN_HOST=0.0.0.0
FLASK_ENV=development
SECRET_KEY=deliveroo-secret-key-2024

# MySQL Database Settings for Docker
DB_HOST=db
MYSQL_DATABASE=swiftbite_db
MYSQL_USER=swiftbite
MYSQL_PASSWORD=swiftpass
MYSQL_ROOT_PASSWORD=rootpass

# SQLAlchemy Connection String (Used by Flask)
# MySQL (Docker only): DATABASE_URL=mysql+pymysql://${MYSQL_USER}:${MYSQL_PASSWORD}@${DB_HOST}/${MYSQL_DATABASE}
DATABASE_URL=sqlite:///deliveroo.db
